model Company {
  id          String   @id @default(uuid())
  name        String
  description String
  location    String
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  job         Job[] // one-to-many relationship with Job

// Relation: A Company belongs to one User (Owner)
  // ownerId     String   @unique // This must be @unique for 1-to-1
  // owner       User     @relation(fields: [ownerId], references: [id])



  creatorId String
  creator   User     @relation("UserCreatedCompanies", fields: [creatorId], references: [id])

  @@map("companies") // maps to "companies" table in DB
}

